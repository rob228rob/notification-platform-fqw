// profile-consent PostgreSQL
// Example data: docs/plantuml/examples/profile-consent-postgres-example.json

Table nf_prof.recipient_profile {
  recipient_id varchar(128) [pk]
  active boolean [not null]
  preferred_channel varchar(32)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Indexes {
    (updated_at) [name: 'idx_recipient_profile_updated_at']
  }
}

Table nf_prof.recipient_channel_consent {
  consent_id bigint [pk, increment]
  recipient_id varchar(128) [not null]
  channel varchar(32) [not null]
  tenant_key varchar(128)
  enabled boolean [not null]
  blacklisted boolean [not null]
  destination varchar(256)
  updated_at timestamptz [not null]

  Indexes {
    (recipient_id, channel, tenant_key) [unique, name: 'idx_recipient_channel_consent_lookup']
    (channel, tenant_key) [name: 'idx_recipient_channel_consent_channel_tenant']
  }
}

Ref: nf_prof.recipient_channel_consent.recipient_id > nf_prof.recipient_profile.recipient_id
