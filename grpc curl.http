Content-Type: application/grpc
TE: trailers

{
  "eventId": "{{event_id_3}}",
  "idempotencyKey": "mail-batch-add-{{$timestamp}}-3",
  "recipientId": [
    "mail-user-1006",
    "mail-user-1007"
  ]
}

