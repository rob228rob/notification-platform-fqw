TE: trailers

{
  "idempotencyKey": "mail-batch-{{$timestamp}}-3",
  "templateId": "digest-email",
  "templateVersion": 2,
  "priority": "DELIVERY_PRIORITY_LOW",
  "preferredChannel": "CHANNEL_EMAIL",
  "strategy": {
    "kind": "STRATEGY_KIND_IMMEDIATE"
  },
