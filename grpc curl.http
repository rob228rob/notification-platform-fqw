    "campaign": "spring-batch-c1",
    "title": "Digest C1",
    "body": "Third mail event from grpc curl"
  },
  "audience": {
    "kind": "AUDIENCE_KIND_EXPLICIT",
    "snapshotOnDispatch": true
  }
}
> {% client.global.set("event_id_3", response.body.eventId); %}

